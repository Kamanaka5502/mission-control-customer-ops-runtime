APP_ENV=production
APP_MODE=customer-operations-platform
DATABASE_URL=postgresql+psycopg://mission_control:change_me@postgres:5432/mission_control
REQUIRE_TENANT_HEADER=true
REQUIRE_TRUSTED_INGRESS=true
AUTH_REQUIRED=true
AUTH_TOKEN_SECRET=
RECEIPT_SIGNING_SECRET=
CORS_ALLOW_ORIGINS=https://app.example.com
NEXT_PUBLIC_API_BASE=https://api.example.com
MAX_REQUEST_BODY_BYTES=262144
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Deploy the API on a private network behind authenticated ingress.
# The ingress layer must strip inbound identity headers from public traffic.
# It must inject x-ingress-verified=true and x-tenant-id only after authentication.
# Runtime actors must authenticate with signed bearer tokens when AUTH_REQUIRED=true.
# AUTH_TOKEN_SECRET and RECEIPT_SIGNING_SECRET must be supplied from a secret manager or deployment environment.
# MAX_REQUEST_BODY_BYTES, RATE_LIMIT_REQUESTS, and RATE_LIMIT_WINDOW_SECONDS define the API intake boundary.
